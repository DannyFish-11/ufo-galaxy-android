<?xml version="1.0" encoding="utf-8"?>
<!--
  B4-FIX: Release-only Network Security Configuration.
  Strict: cleartext is completely disabled. Only system CAs are trusted.
  This file is referenced in build.gradle release buildType.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- Domain-specific: stricter for known remote endpoints -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">huggingface.co</domain>
        <domain includeSubdomains="true">github.com</domain>
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>
</network-security-config>
