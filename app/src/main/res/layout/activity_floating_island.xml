<?xml version="1.0" encoding="utf-8"?>
<!--
  Mode-toggle UI for FloatingIslandActivity (PR-MODE-TOGGLE).

  This is a compact, floating-style overlay that shows the current execution mode
  and allows the user to toggle between local-only and cross-device modes.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floatingIslandRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:background="@drawable/floating_island_background">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UFO Galaxy"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mode"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:textColor="?android:attr/textColorSecondary" />

        <!-- Mode toggle button -->
        <Button
            android:id="@+id/btnModeToggle"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="Cross-Device"
            android:textSize="14sp" />

        <!-- Close button -->
        <Button
            android:id="@+id/btnClose"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="Close"
            style="?attr/materialButtonOutlinedStyle" />

    </LinearLayout>
</FrameLayout>
