<?xml version="1.0" encoding="utf-8"?>
<!-- 浮动灵动岛容器背景:圆角深色底,与 dynamic_island_bg 视觉一致。
     activity_floating_island.xml 引用此 drawable;此前缺失导致 AAPT2
     资源链接期 "resource drawable/floating_island_background not found"、
     :app:processDebugResources 失败,阻塞整个 app 构建。 -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="@color/island_background" />

    <corners android:radius="28dp" />

    <stroke
        android:width="1dp"
        android:color="@color/island_content" />

</shape>
